<script>
function updateForm() {
    var category = document.getElementById("assetSelector").value;

    document.getElementById("cpu_fields").style.display = "none";
    document.getElementById("monitor_fields").style.display = "none";
    document.getElementById("printer_fields").style.display = "none";
    document.getElementById("other_fields").style.display = "none";

    if(category === "CPU") document.getElementById("cpu_fields").style.display = "block";
    if(category === "Monitor") document.getElementById("monitor_fields").style.display = "block";
    if(category === "Printer") document.getElementById("printer_fields").style.display = "block";
    if(category === "Other") document.getElementById("other_fields").style.display = "block";
}
</script>
